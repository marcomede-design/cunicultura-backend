generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  animais   Animal[]
  lotes     LoteEngorda[]
}

model Animal {
  id             Int      @id @default(autoincrement())
  nome           String
  sexo           String
  historico      String?
  raca           String?
  pesoMonta      Float?
  createdAt      DateTime @default(now())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  reproducoesComomMatrix    Reproducao[] @relation("MatrizReproducoes")
  coberturasComomReprodutor Reproducao[] @relation("ReprodutorCoberturas")
  alimentacoes              Alimentacao[]
  registrosSaude            Saude[]
}

model Reproducao {
  id                     Int       @id @default(autoincrement())
  dataCobertura          DateTime
  tipoCobracao           String?
  dataConfirmacaoPrenhez DateTime?
  diagGestacao           String?
  confirmadaPrenhez      Boolean   @default(false)
  dataParto              DateTime?
  dataDesmame            DateTime?
  observacoes            String?
  createdAt              DateTime  @default(now())
  matrizId     Int
  matriz       Animal   @relation("MatrizReproducoes", fields: [matrizId], references: [id])
  reproducaoId Int?
  reprodutor   Animal?  @relation("ReprodutorCoberturas", fields: [reproducaoId], references: [id])
  ninhada Ninhada?
}

model Ninhada {
  id               Int       @id @default(autoincrement())
  totalNascidos    Int
  nascidosVivos    Int
  nascidosMortos   Int
  machos           Int?
  femeas           Int?
  pesoMedioNascer  Float?
  pesoMedioDesmame Float?
  vivosAtual       Int?
  createdAt        DateTime  @default(now())
  reproducaoId Int        @unique
  reproducao   Reproducao @relation(fields: [reproducaoId], references: [id])
  mortalidades Mortalidade[]
}

model Mortalidade {
  id         Int      @id @default(autoincrement())
  data       DateTime
  quantidade Int
  causa      String?
  createdAt  DateTime @default(now())
  ninhadaId Int
  ninhada   Ninhada @relation(fields: [ninhadaId], references: [id])
}

model Alimentacao {
  id          Int      @id @default(autoincrement())
  data        DateTime
  tipo        String
  quantidade  Float
  unidade     String
  observacoes String?
  createdAt   DateTime @default(now())
  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])
}

model Saude {
  id          Int      @id @default(autoincrement())
  data        DateTime
  tipo        String
  descricao   String
  tratamento  String?
  medicamento String?
  dose        String?
  observacoes String?
  resolvido   Boolean  @default(false)
  createdAt   DateTime @default(now())
  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])
}

model LoteEngorda {
  id          Int       @id @default(autoincrement())
  nome        String
  descricao   String?
  dataInicio  DateTime
  dataFim     DateTime?
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  pesagens    Pesagem[]
  consumos    ConsumoAlimento[]
}

model Pesagem {
  id          Int      @id @default(autoincrement())
  data        DateTime
  pesoTotal   Float
  qtdAnimais  Int
  pesoMedio   Float
  observacoes String?
  createdAt   DateTime @default(now())
  loteId      Int
  lote        LoteEngorda @relation(fields: [loteId], references: [id])
}

model ConsumoAlimento {
  id          Int      @id @default(autoincrement())
  data        DateTime
  tipo        String
  marca       String?
  quantidade  Float
  unidade     String   @default("kg")
  observacoes String?
  createdAt   DateTime @default(now())
  loteId      Int
  lote        LoteEngorda @relation(fields: [loteId], references: [id])
}