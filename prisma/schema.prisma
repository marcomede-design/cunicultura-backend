generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Animal {
  id           Int      @id @default(autoincrement())
  brinco       String
  sexo         String
  raca         String
  nascimento   DateTime
  status       String
  peso         Float?
  gaiola       String?
  categoria    String?

  coberturasComoMatriz Cobertura[] @relation("MatrizCobertura")
  coberturasComoMacho  Cobertura[] @relation("MachoCobertura")

  ninhadas Ninhada[]
}

model Cobertura {
  id              Int      @id @default(autoincrement())
  matrizId        Int
  machoId         Int
  dataCobertura   DateTime
  previsaoParto   DateTime

  matriz Animal @relation("MatrizCobertura", fields: [matrizId], references: [id])
  macho  Animal @relation("MachoCobertura", fields: [machoId], references: [id])
}

model Ninhada {
  id         Int      @id @default(autoincrement())
  matrizId   Int
  dataParto  DateTime
  nascidos   Int
  mortos     Int
  observacao String?

  matriz Animal @relation(fields: [matrizId], references: [id])
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  senha String
}