generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  animais   Animal[]
}

model Animal {
  id        Int      @id @default(autoincrement())
  nome      String
  sexo      String
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  reproducoesComomMatrix  Reproducao[] @relation("MatrizReproducoes")
  coberturasComomReprodutor Reproducao[] @relation("ReprodutorCoberturas")
}

model Reproducao {
  id                    Int       @id @default(autoincrement())
  dataCobertura         DateTime
  dataConfirmacaoPrenhez DateTime?
  confirmadaPrenhez     Boolean   @default(false)
  dataParto             DateTime?
  dataDesmame           DateTime?
  observacoes           String?
  createdAt             DateTime  @default(now())

  matrizId    Int
  matriz      Animal   @relation("MatrizReproducoes", fields: [matrizId], references: [id])
  reproducaoId Int?
  reprodutor  Animal?  @relation("ReprodutorCoberturas", fields: [reproducaoId], references: [id])

  ninhada     Ninhada?
}

model Ninhada {
  id              Int       @id @default(autoincrement())
  totalNascidos   Int
  nascidosVivos   Int
  nascidosMortos  Int
  machos          Int?
  femeas          Int?
  pesoMedioNascer Float?
  pesoMedioDesmame Float?
  vivosAtual      Int?
  createdAt       DateTime  @default(now())

  reproducaoId    Int       @unique
  reproducao      Reproducao @relation(fields: [reproducaoId], references: [id])

  mortalidades    Mortalidade[]
}

model Mortalidade {
  id          Int      @id @default(autoincrement())
  data        DateTime
  quantidade  Int
  causa       String?
  createdAt   DateTime @default(now())

  ninhadaId   Int
  ninhada     Ninhada  @relation(fields: [ninhadaId], references: [id])
}